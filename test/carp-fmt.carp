(load "../carp-fmt.carp")
(Project.no-echo)
(load "Test.carp")

(use-all Test)

(defn fmt! [src] (Result.unsafe-from-success (Fmt.format-source src)))

(deftest t
  (assert-equal t "42
" &(fmt! "42") "integer atom round-trips")
  (assert-equal t "true
" &(fmt! "true") "bool atom round-trips")
  (assert-equal t "\"hi\"
" &(fmt! "\"hi\"") "string atom round-trips")
  (assert-equal t "foo-bar
" &(fmt! "foo-bar") "symbol atom round-trips")
  (assert-equal t "Foo.Bar.baz
" &(fmt! "Foo.Bar.baz") "dotted symbol round-trips")

  (assert-equal t "(do x)
" &(fmt! "(do x)") "short list stays inline")
  (assert-equal t "[1 2 3]
" &(fmt! "[1 2 3]") "short array stays inline")
  (assert-equal t "{:a 1}
" &(fmt! "{:a 1}") "short dict stays inline")

  ; Two top-level forms, newline separation
  (assert-equal t "1
2
" &(fmt! "1
2") "two top-level atoms separated by newline")

  ; Width-driven breaking: a list that exceeds 80 columns should
  ; render broken regardless of source bias.
  (assert-true
    t
    (String.contains-string?
      &(fmt!
        "(foo aaaaaaaaaaaaaaaaaaaaaa bbbbbbbbbbbbbbbbbbbbbb cccccccccccccccccccccc dddddddddddddddddddddd)")
      "
")
    "wide list breaks when it exceeds page-width")

  ; A short multi-line list auto-inlines when it fits — the
  ; formatter is opinionated, not source-preserving.
  (assert-equal t "(a b)
" &(fmt! "(a
  b)") "short multi-line auto-inlines")

  ; Conversely: a short single-line list stays inline.
  (assert-equal t "(a b c)
" &(fmt! "(a b c)") "single-line source stays inline")

  ; Top-level comment.
  (assert-equal t "; hello
42
" &(fmt! "; hello
42") "top-level comment retains newline before next form")

  ; Comment inside a list forces break.
  (assert-true t (String.contains-string? &(fmt! "(a ; mid
 b)") "
") "list containing a comment renders broken")

  ; Reader macros round-trip with their original syntax.
  (assert-equal t "&x
" &(fmt! "&x") "ref reader macro")
  (assert-equal t "~x
" &(fmt! "~x") "deref reader macro")
  (assert-equal t "@x
" &(fmt! "@x") "copy reader macro")
  (assert-equal t "'x
" &(fmt! "'x") "quote reader macro")
  (assert-equal t "`x
" &(fmt! "`x") "quasiquote reader macro")
  (assert-equal t "%x
" &(fmt! "%x") "unquote reader macro")
  (assert-equal t "%@x
" &(fmt! "%@x") "unquote-splicing reader macro")
  (assert-equal t "&(f x)
" &(fmt! "&(f x)") "ref macro around compound form")

  ; ----------------------------------------------------------------
  ; Special-form layouts.
  ; ----------------------------------------------------------------

  ; Short single-line forms stay inline.
  (assert-equal t "(defn foo [x] (+ x 1))
" &(fmt! "(defn foo [x] (+ x 1))") "short defn stays inline")
  (assert-equal t "(let [a 1] a)
" &(fmt! "(let [a 1] a)") "short let stays inline")
  (assert-equal t "(when c x)
" &(fmt! "(when c x)") "short when stays inline")
  (assert-equal t "(do x y z)
" &(fmt! "(do x y z)") "short do stays inline")

  ; Short multi-line special forms auto-inline when they fit.
  (assert-equal t "(defn foo [x] (+ x 1))
" &(fmt! "(defn foo [x]
  (+ x 1))") "short multi-line defn auto-inlines")
  ; A defn too wide for one line stays broken at +2.
  (assert-true
    t
    (String.contains-string?
      &(fmt!
        "(defn really-long-fn-name [argument-one argument-two argument-three] (Int.+ argument-one argument-two argument-three))")
      "
  ")
    "wide defn body wraps at +2")

  ; ----------------------------------------------------------------
  ; Idempotency: formatting twice equals formatting once.
  ; ----------------------------------------------------------------

  (assert-true t (let [once (fmt! "(defn foo [x]
  (+ x 1))")
                       twice (fmt! &once)] (= &once &twice)) "idempotent on multi-line defn")
  (assert-true
    t
    (let [once (fmt! "(do x y z)")
          twice (fmt! &once)] (= &once &twice))
    "idempotent on short do")
  (assert-true
    t
    (let [once (fmt!
            "(defmodule Math (defn square [x] (* x x)) (defn cube [x] (* (Math.square x) x)))")
          twice (fmt! &once)]
      (= &once &twice))
    "idempotent on nested defns inside defmodule")

  ; Short match auto-inlines, like everything else.
  (assert-equal t "(match x (A a) 1 (B b) 2)
" &(fmt! "(match x (A a) 1 (B b) 2)") "short match stays inline")
  ; A wider match breaks pair-aware: each pair on its own line; if a
  ; pair itself is too wide, pattern goes on its own line and result
  ; is indented under it.
  (assert-true
    t
    (String.contains-string?
      &(fmt!
        "(match scrutinee (LongPatternA a b c) (do-something a b c) (LongPatternB d e f) (do-other d e f))")
      "
  (LongPatternA a b c)")
    "wide match: each pair on its own line")

  ; ----------------------------------------------------------------
  ; blank lines between top-level forms are preserved when present
  ; in the source.
  ; ----------------------------------------------------------------
  (assert-equal t "1
2
" &(fmt! "1
2") "no blank line: forms touch")
  (assert-equal t "1

2
" &(fmt! "1

2") "single blank line preserved")
  (assert-equal t "1

2
" &(fmt! "1



2") "multiple blank lines collapse to one")

  ; ----------------------------------------------------------------
  ; multi-line string literals stay multi-line, not `\n`-escaped.
  ; ----------------------------------------------------------------
  (assert-equal t "\"a
b\"
" &(fmt! "\"a
b\"") "literal newline inside string stays literal")

  ; Blank lines inside compound forms are preserved too.
  (assert-equal t "(defmodule M
  (defn a [] 1)

  (defn b [] 2))
" &(fmt! "(defmodule M
  (defn a [] 1)

  (defn b [] 2))") "blank line between defmodule members preserved"))
